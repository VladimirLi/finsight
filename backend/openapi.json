  "paths": {
    "/api/companies": {
      "get": {
        "description": "Return all companies ordered by name.",
        "operationId": "list_companies_api_companies_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/CompanyOut"
                  },
                  "title": "Response List Companies Api Companies Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Companies",
        "tags": [
          "companies"
        ]
      },
      "post": {
        "description": "Create a new company record.",
        "operationId": "create_company_api_companies_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCompanyIn"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Company",
        "tags": [
          "companies"
        ]
      }
    },
    "/api/companies/{company_id}": {
      "get": {
        "description": "Return a company with its associated period summaries.",
        "operationId": "get_company_api_companies__company_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "company_id",
            "required": true,
            "schema": {
              "title": "Company Id",
              "type": "integer"
            }
          }
        ],
