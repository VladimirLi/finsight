                "schema": {
                  "$ref": "#/components/schemas/CompanyDetailOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Company",
        "tags": [
          "companies"
        ]
      }
    },
    "/api/companies/{company_id}/ratios": {
      "get": {
        "description": "Compute ratios for every period belonging to the company.\n\nReturns a time-series suitable for trend charts. Valuation ratios that require\nmarket data will be ``unavailable`` here \u2014 use GET /periods/{id}/ratios with\nquery params for those.",
        "operationId": "get_company_ratios_api_companies__company_id__ratios_get",
        "parameters": [
          {
            "in": "path",
            "name": "company_id",
            "required": true,
            "schema": {
              "title": "Company Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompanyRatioTrendOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Company Ratios",
        "tags": [
          "companies"
        ]
      }
    },
    "/api/documents": {
      "get": {
        "description": "Return all documents ordered newest-first.",
        "operationId": "list_documents_api_documents_get",
        "responses": {
