        "summary": "List Documents",
        "tags": [
          "documents"
        ]
      }
    },
    "/api/documents/upload": {
      "post": {
        "description": "Accept a PDF upload and queue the extraction pipeline.\n\nStores the file on disk, creates a ``Document`` row, and schedules the\nextraction pipeline as a background task.\n\nReturns HTTP 202 (Accepted) immediately; the client polls\nGET /documents/{id} to watch ``status`` transition through the pipeline stages:\n    uploaded \u2192 parsing \u2192 extracting \u2192 needs_review | ready | failed",
        "operationId": "upload_document_api_documents_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_document_api_documents_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentOut"
                }
