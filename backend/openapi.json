    "/api/periods/{period_id}/ratios": {
      "get": {
        "description": "Compute all financial ratios for the given period.\n\nRatios are computed deterministically from the stored canonical line items \u2014\nnever by an LLM.  Each result carries a ``status``:\n- ``ok``          \u2014 value computed successfully\n- ``unavailable`` \u2014 one or more required inputs were missing\n- ``undefined``   \u2014 math is undefined (e.g. division by zero)\n\nPass ``market_price`` and/or ``shares_outstanding`` to unlock valuation\nratios (P/E, EV/EBITDA, etc.).  Omitting them leaves those ratios as\n``unavailable`` rather than erroring.",
        "operationId": "get_period_ratios_api_periods__period_id__ratios_get",
        "parameters": [
          {
            "in": "path",
            "name": "period_id",
            "required": true,
            "schema": {
              "title": "Period Id",
              "type": "integer"
            }
          },
          {
            "description": "Current share price in reporting currency. Required for valuation ratios.",
            "in": "query",
            "name": "market_price",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Current share price in reporting currency. Required for valuation ratios.",
              "title": "Market Price"
            }
          },
          {
            "description": "Shares outstanding (absolute count, not millions). Required for market-cap-based valuation ratios. Falls back to the value extracted from the income statement when absent.",
            "in": "query",
            "name": "shares_outstanding",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Shares outstanding (absolute count, not millions). Required for market-cap-based valuation ratios. Falls back to the value extracted from the income statement when absent.",
              "title": "Shares Outstanding"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RatioReportOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Period Ratios",
        "tags": [
          "ratios"
        ]
      }
    },
    "/api/periods/{period_id}/validation": {
      "get": {
        "description": "Run deterministic accounting-identity checks for the given period.\n\nVerifies accounting equations (assets = liabilities + equity, subtotals foot to\ntotals, gross_profit = revenue - COGS, etc.) within a rounding tolerance. Each\nresult carries a ``status``:\n- ``ok``          \u2014 the identity holds within tolerance\n- ``mismatch``    \u2014 the figures do not reconcile (likely an extraction error)\n- ``unavailable`` \u2014 one or more required line items were not reported\n\nLike ratios, these are computed in pure Python, never by an LLM, so the UI can\nflag inconsistent extractions instead of trusting bad data silently.",
        "operationId": "get_period_validation_api_periods__period_id__validation_get",
        "parameters": [
          {
            "in": "path",
            "name": "period_id",
            "required": true,
            "schema": {
              "title": "Period Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationReportOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Period Validation",
        "tags": [
          "ratios"
        ]
      }
    }
